---
export interface Benefit {
  title: string;
  description: string;
  stat: string;
  statLabel: string;
}

export interface Props {
  benefits: Benefit[];
}

const { benefits } = Astro.props;
---

<ul role="list" class="grid gap-6 md:grid-cols-2">
  {benefits.map((benefit) => (
    <li class="flex gap-6 rounded-2xl border border-[color:var(--color-border)] bg-white p-6">
      <div class="flex shrink-0 flex-col items-center justify-center rounded-xl bg-[color:var(--color-accent)]/10 px-4 py-3 text-center">
        <span class="text-3xl font-extrabold text-[color:var(--color-accent)]">
          {benefit.stat}
        </span>
        <span class="mt-1 text-xs font-medium uppercase tracking-wide text-[color:var(--color-muted-foreground)]">
          {benefit.statLabel}
        </span>
      </div>
      <div>
        <h3 class="mb-2 text-lg font-semibold text-[color:var(--color-foreground)]">
          {benefit.title}
        </h3>
        <p class="text-sm leading-relaxed text-[color:var(--color-muted-foreground)]">
          {benefit.description}
        </p>
      </div>
    </li>
  ))}
</ul>

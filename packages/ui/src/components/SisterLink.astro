---
export interface Props {
  intro: string;
  description: string;
  cta: { label: string; href: string };
  /** Visual emphasis level. "soft" = standalone band, "footer-strip" = compact. */
  variant?: "soft" | "compact";
}

const { intro, description, cta, variant = "soft" } = Astro.props;
---

{variant === "soft" ? (
  <section class="border-t border-[color:var(--color-border)] bg-white py-14" aria-label="Schwestermarke">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <p class="mb-2 text-sm font-medium text-[color:var(--color-muted-foreground)]">{intro}</p>
      <p class="mb-4 text-sm text-[color:var(--color-muted-foreground)]" set:html={description} />
      <a
        href={cta.href}
        class="inline-flex items-center rounded-md border border-[color:var(--color-border)] px-4 py-2 text-sm font-medium text-[color:var(--color-foreground)] transition-colors hover:bg-[color:var(--color-muted)]"
      >
        {cta.label}
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </div>
  </section>
) : (
  <p class="text-sm text-[color:var(--color-muted-foreground)]">
    {intro}{" "}
    <a href={cta.href} class="font-medium text-[color:var(--color-accent)] hover:underline">
      {cta.label}
    </a>
  </p>
)}

---
export interface PricingFeature {
  text: string;
  included: boolean;
}

export interface PricingTier {
  name: string;
  price: string;
  period?: string;
  description: string;
  highlighted?: boolean;
  cta: { label: string; href: string };
  features: PricingFeature[];
}

export interface Props {
  tiers: PricingTier[];
  footnote?: string;
}

const { tiers, footnote } = Astro.props;
---

<ul role="list" class="mx-auto grid max-w-4xl gap-8 md:grid-cols-2">
  {tiers.map((tier) => (
    <li
      class={`relative flex flex-col rounded-2xl border bg-white p-8 ${
        tier.highlighted
          ? "border-2 border-[color:var(--color-accent)] shadow-glow-accent"
          : "border-[color:var(--color-border)]"
      }`}
    >
      {tier.highlighted && (
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-[color:var(--color-accent)] px-3 py-1 text-xs font-semibold text-[color:var(--color-accent-foreground)]">
          Empfohlen
        </span>
      )}

      <header>
        <h3 class="text-xl font-bold text-[color:var(--color-foreground)]">{tier.name}</h3>
        <p class="mt-1 text-sm text-[color:var(--color-muted-foreground)]">{tier.description}</p>
        <p class="mt-4">
          <span class="text-4xl font-extrabold text-[color:var(--color-foreground)]">{tier.price}</span>
          {tier.period && (
            <span class="ml-1 text-[color:var(--color-muted-foreground)]">{tier.period}</span>
          )}
        </p>
      </header>

      <ul role="list" class="mt-6 flex-1 space-y-3">
        {tier.features.map((f) => (
          <li class="flex items-center gap-2 text-sm">
            {f.included ? (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-[color:var(--color-accent)]" aria-hidden="true">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            ) : (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-[color:var(--color-muted-foreground)]/40" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
              </svg>
            )}
            <span class={f.included ? "text-[color:var(--color-foreground)]" : "text-[color:var(--color-muted-foreground)]/60 line-through"}>
              {f.text}
            </span>
          </li>
        ))}
      </ul>

      <a
        href={tier.cta.href}
        class={`mt-8 inline-flex w-full items-center justify-center rounded-md px-4 py-3 text-base font-semibold transition-colors ${
          tier.highlighted
            ? "bg-[color:var(--color-accent)] text-[color:var(--color-accent-foreground)] hover:bg-[color:var(--color-accent-hover)]"
            : "border border-[color:var(--color-border)] text-[color:var(--color-foreground)] hover:bg-[color:var(--color-muted)]"
        }`}
      >
        {tier.cta.label}
      </a>
    </li>
  ))}
</ul>

{footnote && (
  <p class="mt-8 text-center text-sm text-[color:var(--color-muted-foreground)]">
    {footnote}
  </p>
)}

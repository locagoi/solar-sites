---
export interface Props {
  badge?: string;
  /** Heading split into pre-accent and accent parts. e.g. ["Mehr qualifizierte", "Solar-Leads."] + tail "Automatisch." */
  headingLead: string;
  headingAccent: string;
  headingTail?: string;
  subhead: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  trustPoints?: string[];
}

const { badge, headingLead, headingAccent, headingTail, subhead, primaryCta, secondaryCta, trustPoints = [] } = Astro.props;
---

<section class="gradient-hero py-16 text-white md:py-24" aria-labelledby="hero-heading">
  <div class="mx-auto max-w-4xl px-6 text-center">
    {badge && (
      <span
        class="mb-4 inline-block rounded-full border border-[color:var(--color-accent)]/30 bg-[color:var(--color-accent)]/20 px-4 py-1.5 text-sm font-medium text-[color:var(--color-accent)]"
      >
        {badge}
      </span>
    )}

    <h1 id="hero-heading" class="text-4xl font-extrabold leading-tight md:text-6xl">
      {headingLead}<br />
      <span class="text-[color:var(--color-accent)]">{headingAccent}</span>
      {headingTail && <> {headingTail}</>}
    </h1>

    <p class="mx-auto mt-4 max-w-2xl text-lg text-white/80 md:text-xl">
      {subhead}
    </p>

    <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
      <a
        href={primaryCta.href}
        class="inline-flex items-center justify-center rounded-md bg-[color:var(--color-accent)] px-6 py-3 text-base font-semibold text-[color:var(--color-accent-foreground)] shadow-lg transition-colors hover:bg-[color:var(--color-accent-hover)]"
      >
        {primaryCta.label}
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
      {secondaryCta && (
        <a
          href={secondaryCta.href}
          class="inline-flex items-center justify-center rounded-md border border-white/30 px-6 py-3 text-base font-medium text-white transition-colors hover:bg-white/10"
        >
          {secondaryCta.label}
        </a>
      )}
    </div>

    {trustPoints.length > 0 && (
      <ul class="mt-6 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-white/70" aria-label="Vertrauenshinweise">
        {trustPoints.map((point) => (
          <li class="flex items-center gap-1.5">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[color:var(--color-accent)]" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
              <polyline points="22 4 12 14.01 9 11.01" />
            </svg>
            {point}
          </li>
        ))}
      </ul>
    )}
  </div>
</section>

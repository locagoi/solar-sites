---
export interface FaqItem {
  question: string;
  answer: string;
}

export interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

{/*
  Native <details>/<summary> — semantic, zero-JS, screen-reader-friendly, and the answers
  are in the DOM at render time so crawlers/agents and JSON-LD FAQPage stay in sync.
*/}
<div class="mx-auto max-w-3xl divide-y divide-[color:var(--color-border)]">
  {items.map((item, i) => (
    <details class="group py-4" name="faq-accordion" open={i === 0}>
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-base font-medium text-[color:var(--color-foreground)] [&::-webkit-details-marker]:hidden">
        <span>{item.question}</span>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-[color:var(--color-muted-foreground)] transition-transform group-open:rotate-180" aria-hidden="true">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </summary>
      <div class="mt-3 text-sm leading-relaxed text-[color:var(--color-muted-foreground)]">
        {item.answer}
      </div>
    </details>
  ))}
</div>

---
export interface Step {
  number: string;
  title: string;
  description: string;
}

export interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<ol role="list" class="grid gap-8 md:grid-cols-3">
  {steps.map((step) => (
    <li class="text-center">
      <span
        class="gradient-accent shadow-glow-accent mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full text-xl font-bold text-[color:var(--color-accent-foreground)]"
        aria-hidden="true"
      >
        {step.number}
      </span>
      <h3 class="mb-2 text-xl font-semibold text-[color:var(--color-foreground)]">
        <span class="sr-only">Schritt {step.number}: </span>
        {step.title}
      </h3>
      <p class="leading-relaxed text-[color:var(--color-muted-foreground)]">
        {step.description}
      </p>
    </li>
  ))}
</ol>

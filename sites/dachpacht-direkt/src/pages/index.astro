---
import BaseLayout from "@solar/ui/layouts/BaseLayout.astro";
import Navbar from "@solar/ui/components/Navbar.astro";
import Hero from "@solar/ui/components/Hero.astro";
import Section from "@solar/ui/components/Section.astro";
import FeatureGrid from "@solar/ui/components/FeatureGrid.astro";
import HowItWorks from "@solar/ui/components/HowItWorks.astro";
import Faq from "@solar/ui/components/Faq.astro";
import FinalCta from "@solar/ui/components/FinalCta.astro";
import Footer from "@solar/ui/components/Footer.astro";
import { brand } from "../config/brand";

const title = "Dachfläche vermieten — Passive Einnahmen ohne Aufwand | Dachpacht Direkt";
const description =
  "Vermieten Sie Ihr Gewerbedach für Solaranlagen. Kostenlos und unverbindlich. Geprüfte PV-Anbieter aus Ihrer Region. Jetzt Angebote erhalten.";

const navLinks = [
  { label: "Vorteile", href: "#vorteile" },
  { label: "Ablauf", href: "#how-it-works" },
  { label: "FAQ", href: "#faq" },
  { label: "Angebot anfordern", href: "#kontakt" },
];

const benefits = [
  {
    iconPath: "M12 1v22 M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6",
    title: "IAB Steuervorteile",
    description:
      "Sofortige Liquidität & bis zu 50% Investitionskosten vorab absetzen.",
  },
  {
    iconPath: "M13 2 3 14h9l-1 8 10-12h-9z",
    title: "Energiekosten senken",
    description:
      "Fixkosten dauerhaft reduzieren durch günstigen Eigenstrom.",
  },
  {
    iconPath: "M3 21h18 M5 21V7l8-4v18 M19 21V11l-6-4",
    title: "Einnahmen durch Pacht",
    description:
      "Passives Einkommen ohne eigenes Risiko oder Investition.",
  },
  {
    iconPath: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
    title: "Unabhängigkeit",
    description:
      "Planungssicherheit und Schutz vor steigenden Strompreisen.",
  },
  {
    iconPath: "M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z M2 21c0-3 1.85-5.36 5.08-6",
    title: "Grünes Image stärken",
    description:
      "CO₂-Bilanz verbessern und Nachhaltigkeit bei Kunden & Partnern sichtbar machen.",
  },
  {
    iconPath: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M9 15l2 2 4-4",
    title: "Förderungen nutzen",
    description:
      "KfW-Programme, Steuerabschreibungen und Einspeisevergütung optimal ausschöpfen.",
  },
];

const steps = [
  {
    number: "1",
    title: "Daten eingeben",
    description:
      "Füllen Sie unser einfaches Formular mit Ihren Dachdetails aus — Adresse, Dachgröße, Eigentumssituation.",
  },
  {
    number: "2",
    title: "Angebote erhalten",
    description:
      "Sie erhalten kostenlose, unverbindliche Angebote von geprüften PV-Anbietern aus Ihrer Region.",
  },
  {
    number: "3",
    title: "Besten Partner wählen",
    description:
      "Vergleichen Sie in Ruhe und wählen Sie Ihren Wunschpartner — oder entscheiden Sie sich gegen alle Angebote, ohne Kosten.",
  },
];

const faqItems = [
  {
    question: "Was kostet die Anfrage?",
    answer:
      "Die Anfrage ist für Sie zu 100% kostenlos und unverbindlich. Wir finanzieren uns ausschließlich über die vermittelten PV-Anbieter — Ihnen entstehen niemals Kosten, weder für die Anfrage noch für die Angebote.",
  },
  {
    question: "Welche Dächer eignen sich?",
    answer:
      "In erster Linie Gewerbedächer ab ca. 500 m² (Logistikhallen, Industriebauten, Lagerhäuser, Werkstätten, große Gewerbeobjekte). Privat-Einfamilienhäuser sind in der Regel zu klein für unser Modell. Wir geben Ihnen nach Eingabe eine erste Einschätzung.",
  },
  {
    question: "Welche Anbieter erhalten meine Daten?",
    answer:
      "Nur ausgewählte, von uns geprüfte PV-Anbieter aus Ihrer Region — keine Massenstreuung. Jede Anbieter durchläuft eine Verifikation auf Bonität, Referenzen und Zertifizierungen. Sie können der Weitergabe jederzeit widersprechen.",
  },
  {
    question: "Wie funktioniert die Dachverpachtung?",
    answer:
      "Der PV-Anbieter installiert und betreibt die Anlage auf eigene Kosten und zahlt Ihnen über die Laufzeit (typisch 20-30 Jahre) eine Pacht. Sie tragen kein Investitionsrisiko, kein Wartungsaufwand. Alternativ können Sie die Anlage auch selbst finanzieren — wir zeigen Ihnen beide Modelle.",
  },
  {
    question: "Was passiert nach dem Vertragsende?",
    answer:
      "Je nach Vertragsmodell geht die Anlage am Ende der Laufzeit in Ihr Eigentum über (Pachtmodell) oder Sie verlängern. Die Details werden im Pachtvertrag geregelt und sind vor Vertragsabschluss vollständig transparent.",
  },
  {
    question: "Wie schnell erhalte ich Angebote?",
    answer:
      "In der Regel innerhalb von 5 Werktagen. Bei besonders attraktiven Dächern oft schneller — manche Anbieter melden sich schon am nächsten Werktag.",
  },
];

const siteUrl = `https://${brand.domain}`;
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Dachpacht Direkt — Dachflächenvermietung",
    description,
    provider: { "@type": "Organization", name: "CegTec GmbH", url: siteUrl },
    serviceType: "Vermittlung von Dachflächen für Photovoltaikanlagen",
    areaServed: { "@type": "Country", name: "Germany" },
    offers: { "@type": "Offer", price: "0", priceCurrency: "EUR", description: "Kostenlose, unverbindliche Anfrage" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: { "@type": "Answer", text: item.answer },
    })),
  },
];

const footerLinks = [
  { label: "Solar Match (für Solarbetriebe)", href: "https://solar-match.de", external: true },
  { label: "Impressum", href: "/impressum" },
  { label: "Datenschutz", href: "/datenschutz" },
];
---

<BaseLayout brand={brand} title={title} description={description} path="/" jsonLd={jsonLd}>
  <Navbar
    brand={brand}
    links={navLinks}
    primaryCta={{ label: "Jetzt anfragen", href: "#kontakt" }}
  />

  <main id="main">
    <Hero
      badge="Für Industrie, Logistik & Gewerbe"
      headingLead="Ihre Dachfläche."
      headingAccent="Passive Einnahmen."
      subhead="Vermieten Sie Ihr Gewerbedach für Solaranlagen — kostenlos und unverbindlich. Wir vermitteln Sie an geprüfte PV-Anbieter aus Ihrer Region."
      primaryCta={{ label: "Jetzt Angebote erhalten", href: "#kontakt" }}
      secondaryCta={{ label: "So funktioniert's", href: "#how-it-works" }}
      trustPoints={["100% kostenlos", "Unverbindlich", "Geprüfte Anbieter"]}
    />

    <Section
      id="vorteile"
      bg="subtle"
      title="Ihre Vorteile auf einen Blick"
      intro="Wir machen es Ihnen einfach, das Beste aus Ihrer Dachfläche herauszuholen."
    >
      <FeatureGrid features={benefits} cols={3} />
    </Section>

    <Section
      id="how-it-works"
      title="So einfach funktioniert's"
      intro="In nur drei Schritten zu Ihrem PV-Angebot."
    >
      <HowItWorks steps={steps} />
    </Section>

    <Section id="faq" bg="subtle" title="Häufige Fragen">
      <Faq items={faqItems} />
    </Section>

    <section id="kontakt" class="bg-white py-14 md:py-20" aria-labelledby="kontakt-heading">
      <div class="mx-auto max-w-2xl px-6">
        <header class="mb-8 text-center">
          <h2 id="kontakt-heading" class="text-3xl font-bold text-[color:var(--color-foreground)] md:text-4xl">
            Angebot anfordern
          </h2>
          <p class="mx-auto mt-4 max-w-xl text-lg text-[color:var(--color-muted-foreground)]">
            Beantworten Sie 4 kurze Fragen — wir melden uns innerhalb von 5 Werktagen mit passenden Angeboten.
          </p>
        </header>

        {/*
          Form posts to the existing intake endpoint. Replace `action` once the production endpoint
          is wired up. Keeping it as a real form with named fields so crawlers see the schema.
        */}
        <form
          method="POST"
          action="https://api.dachpacht-direkt.de/intake"
          class="space-y-4 rounded-2xl border border-[color:var(--color-border)] bg-white p-6 shadow-sm"
        >
          <div>
            <label for="company" class="mb-1 block text-sm font-medium text-[color:var(--color-foreground)]">
              Firma / Eigentümer
            </label>
            <input
              type="text"
              id="company"
              name="company"
              required
              class="block w-full rounded-md border border-[color:var(--color-border)] px-3 py-2 text-base focus:border-[color:var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-accent)]/30"
            />
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label for="name" class="mb-1 block text-sm font-medium text-[color:var(--color-foreground)]">
                Ansprechpartner
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="block w-full rounded-md border border-[color:var(--color-border)] px-3 py-2 text-base focus:border-[color:var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-accent)]/30"
              />
            </div>
            <div>
              <label for="email" class="mb-1 block text-sm font-medium text-[color:var(--color-foreground)]">
                E-Mail
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="block w-full rounded-md border border-[color:var(--color-border)] px-3 py-2 text-base focus:border-[color:var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-accent)]/30"
              />
            </div>
          </div>
          <div>
            <label for="address" class="mb-1 block text-sm font-medium text-[color:var(--color-foreground)]">
              Adresse der Dachfläche
            </label>
            <input
              type="text"
              id="address"
              name="address"
              required
              autocomplete="street-address"
              placeholder="Straße, PLZ, Ort"
              class="block w-full rounded-md border border-[color:var(--color-border)] px-3 py-2 text-base focus:border-[color:var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-accent)]/30"
            />
          </div>
          <div>
            <label for="roof_size" class="mb-1 block text-sm font-medium text-[color:var(--color-foreground)]">
              Dachfläche (ca. m²)
            </label>
            <input
              type="number"
              id="roof_size"
              name="roof_size"
              min="100"
              required
              placeholder="z.B. 1500"
              class="block w-full rounded-md border border-[color:var(--color-border)] px-3 py-2 text-base focus:border-[color:var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-accent)]/30"
            />
          </div>
          <label class="flex items-start gap-2 text-sm text-[color:var(--color-muted-foreground)]">
            <input type="checkbox" name="consent" required class="mt-1" />
            <span>
              Ich willige in die Verarbeitung meiner Daten zur Vermittlung an geprüfte PV-Anbieter ein.
              Die Einwilligung kann jederzeit widerrufen werden.
              <a href="/datenschutz" class="text-[color:var(--color-primary)] hover:underline">Datenschutzerklärung</a>
            </span>
          </label>
          <button
            type="submit"
            class="inline-flex w-full items-center justify-center rounded-md bg-[color:var(--color-accent)] px-4 py-3 text-base font-semibold text-[color:var(--color-accent-foreground)] shadow-md transition-colors hover:bg-[color:var(--color-accent-hover)]"
          >
            Angebot anfordern
          </button>
        </form>
      </div>
    </section>

    <FinalCta
      heading="Bereit, Ihre Dachfläche zu vermieten?"
      subhead="Senden Sie uns Ihre Anfrage — wir melden uns mit passenden, geprüften PV-Anbietern aus Ihrer Region."
      cta={{ label: "Jetzt anfragen", href: "#kontakt" }}
      trustPoints={["Keine Kosten", "Keine Verpflichtung", "DSGVO-konform"]}
    />
  </main>

  <Footer brand={brand} links={footerLinks} />
</BaseLayout>
